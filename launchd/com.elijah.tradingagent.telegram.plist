<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>com.elijah.tradingagent.telegram</string>
  <key>ProgramArguments</key><array><string>__PROJECT_ROOT__/scripts/run_telegram_listener.sh</string></array>
  <key>WorkingDirectory</key><string>__PROJECT_ROOT__</string>
  <key>KeepAlive</key><true/>
  <key>RunAtLoad</key><true/>
  <key>StandardOutPath</key><string>__PROJECT_ROOT__/logs/runtime/listener.out</string>
  <key>StandardErrorPath</key><string>__PROJECT_ROOT__/logs/errors/listener.err</string>
  <key>ProcessType</key><string>Background</string>
</dict></plist>
